{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": []
    },
    "dialog:default",
    "fs:default",
    "fs:allow-write-file",
    "fs:scope-resource-recursive",
    "updater:default"
  ]
}
